{
  "version": 2,
  "framework": "vite",
  "installCommand": "NPM_CONFIG_WORKSPACES=false npm ci --prefix frontend && NPM_CONFIG_WORKSPACES=false npm ci --prefix backend",
  "buildCommand": "npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/[...path].js": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...path].js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
